meta {
  name: Redirect
  type: http
  seq: 1
}

get {
  url: {{redirectUrl}}
  body: none
  auth: none
}

tests {
  test("should return 302 Redirect", function () {
    expect(res.getStatus()).to.equal(302);
  });
  
  test("should contain header location", function () {
    expect(res.header).to.have.property("location");
  });
}
