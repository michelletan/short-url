meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{email}}",
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:pre-request {
  const ts = Date.now();
  bru.setEnvVar("email", "test+" + ts + "@example.com");
  bru.setEnvVar("username", "test-user+" + ts);
  bru.setEnvVar("password", "password123");
}

tests {
  status: 200
}
